<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@color/widget_preview_surface_color"
    android:baselineAligned="false"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    tools:ignore="UseCompoundDrawables">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:divider="@drawable/horizontal_space_14dp"
        android:orientation="horizontal"
        android:padding="16dp"
        android:showDividers="middle"
        tools:ignore="UselessParent,hardcodedText">

        <!-- APPOINTMENT -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Dr. Martin"
                android:textColor="@color/addable_type_appointment_color_darkened"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/circle_shape_event"
                android:contentDescription="@string/appointment_annual_checkup"
                android:padding="8dp"
                android:src="@drawable/recurring_event_icon_vector"
                android:tint="@color/addable_type_appointment_color_darkened"
                tools:ignore="UseAppTint" />

            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="22/05/2028"
                android:textColor="@color/widget_preview_text_color"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- DEVICES -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="CGM Sen..."
                android:textColor="@color/device_type_continuous_glucose_monitoring_system_sensor_color_darkened"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/circle_shape_cgm_sensor"
                android:contentDescription="@string/appointment_annual_checkup"
                android:padding="8dp"
                android:src="@drawable/continuous_glucose_monitoring_system_sensor_icon_vector"
                android:tint="@color/device_type_continuous_glucose_monitoring_system_sensor_color_darkened"
                tools:ignore="UseAppTint" />

            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="In 5 days"
                android:textColor="@color/widget_preview_text_color"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical">


            <TextView
                android:id="@+id/textView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="CGM Tra..."
                android:textColor="@color/device_type_continuous_glucose_monitoring_system_transmitter_color_darkened"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/circle_shape_cgm_transmitter"
                android:contentDescription="@string/appointment_annual_checkup"
                android:padding="8dp"
                android:src="@drawable/continuous_glucose_monitoring_system_transmitter_icon_vector"
                android:tint="@color/device_type_continuous_glucose_monitoring_system_transmitter_color_darkened"
                tools:ignore="UseAppTint" />

            <TextView
                android:id="@+id/textView6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="In 2 months"
                android:textColor="@color/widget_preview_text_color"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Pod"
                android:textColor="@color/device_type_wireless_patch_color_darkened"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imageView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/circle_shape_pod"
                android:contentDescription="@string/appointment_annual_checkup"
                android:padding="8dp"
                android:src="@drawable/wireless_patch_icon_vector"
                android:tint="@color/device_type_wireless_patch_color_darkened"
                tools:ignore="UseAppTint" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center|center_horizontal|center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imageView5"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginRight="4dp"
                    android:contentDescription="@string/appointment_annual_checkup"
                    android:src="@drawable/warning_icon_vector"
                    android:tint="@color/widget_preview_error_container"
                    tools:ignore="UseAppTint" />

                <TextView
                    android:id="@+id/textView8"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:textColor="@color/widget_preview_text_color"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>